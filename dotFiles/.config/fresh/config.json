{
  "version": 2,
  "theme": "builtin://light",
  "locale": "en",
  "editor": {
    "diagnostics_inline_text": true,
    "auto_save_enabled": true,
    "trim_trailing_whitespace_on_save": true,
    "completion_popup_auto_show": true,
    "rulers": [
      120
    ],
    "whitespace_spaces_trailing": true
  },
  "file_explorer": {
    "show_hidden": true
  },
  "file_browser": {
    "show_hidden": true
  },
  "keybindings": [
    {
      "key": "l",
      "modifiers": [
        "ctrl",
        "alt"
      ],
      "action": "format_buffer",
      "when": "normal"
    }
  ],
  "active_keybinding_map": "vscode"
}